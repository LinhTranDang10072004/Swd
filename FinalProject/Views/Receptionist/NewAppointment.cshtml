@model FinalProject.ViewModels.AppointmentLookupViewModel
@{
    ViewData["Title"] = "Thêm mới lịch hẹn";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h2 class="mb-1">Thêm mới lịch hẹn</h2>
        <div class="text-muted">Nhập CMND/CCCD để tìm bệnh nhân trước khi đặt lịch.</div>
    </div>
</div>

<div class="row">
    <div class="col-12 col-lg-6">
        <div class="card">
            <div class="card-body">
                <form asp-action="NewAppointment" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="NationalId" class="form-label"></label>
                        <input asp-for="NationalId" class="form-control" />
                        <span asp-validation-for="NationalId" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary">Tìm bệnh nhân</button>
                    <a asp-action="Appointments" class="btn btn-outline-secondary ms-2">Quay lại</a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

