@model FinalProject.Models.MedicalRecord

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2>Medical Record Details</h2>
        <span class="badge @(Model.Status == "Locked" ? "bg-danger" : "bg-success")">@Model.Status</span>
    </div>
    <hr />

    <dl class="row bg-light p-3 rounded">
        <dt class="col-sm-3">Patient Name:</dt>
        <dd class="col-sm-9">@Model.Patient.FullName</dd>

        <dt class="col-sm-3">Visit Date:</dt>
        <dd class="col-sm-9">@Model.VisitDate.ToString("dd/MM/yyyy HH:mm")</dd>

        <dt class="col-sm-3">Chief Complaint (Lý do khám):</dt>
        <dd class="col-sm-9 text-primary fw-bold">@Model.ChiefComplaint</dd>

        <dt class="col-sm-3">Diagnosis (Chẩn đoán):</dt>
        <dd class="col-sm-9 text-primary fw-bold">@Model.Diagnosis</dd>

        <dt class="col-sm-3">Treatment (Hướng điều trị):</dt>
        <dd class="col-sm-9">@Model.Treatment</dd>

        <dt class="col-sm-3">Notes:</dt>
        <dd class="col-sm-9">@Model.Notes</dd>
    </dl>

    <div class="mt-3">
        @if (Model.Status != "LOCKED" && Model.Status != "ARCHIVED" && Model.Status != "CLOSED")
        {
            <a asp-action="Edit" asp-route-id="@Model.RecordId" class="btn btn-warning">Edit Information</a>
        }
        <a asp-action="History" asp-route-patientId="@Model.PatientId" class="btn btn-secondary">Back to List</a>
    </div>
</div>