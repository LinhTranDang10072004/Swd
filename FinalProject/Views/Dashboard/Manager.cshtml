@{
    ViewData["Title"] = "Dashboard - Quản lý";
    var fullName = User.Claims.FirstOrDefault(c => c.Type == "full_name")?.Value ?? User.Identity?.Name;
}

<h2 class="mb-1">Dashboard Quản lý</h2>
<div class="text-muted mb-3">Xin chào, @fullName</div>

<div class="card">
    <div class="card-body">
        <h5 class="card-title">Chức năng gợi ý</h5>
        <div class="text-muted">Báo cáo doanh thu, duyệt mua hàng, quản trị nhân sự…</div>
    </div>
</div>

