@model List<FinalProject.Models.Payment>
@{
    ViewData["Title"] = "Lịch sử thanh toán";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h2 class="mb-1">Lịch sử thanh toán</h2>
        <div class="text-muted">Các giao dịch thanh toán gần đây</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary" asp-action="Invoices">Danh sách hóa đơn</a>
        <a class="btn btn-outline-secondary" asp-controller="Dashboard" asp-action="Patient">Về dashboard</a>
    </div>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-striped align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Thời gian</th>
                    <th>Hóa đơn</th>
                    <th>Phương thức</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Số tiền</th>
                    <th class="text-end"></th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">Chưa có giao dịch thanh toán.</td>
                </tr>
            }
            else
            {
                var i = 1;
                foreach (var p in Model)
                {
                    <tr>
                        <td>@i</td>
                        <td>@p.PaidAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>#@p.InvoiceId</td>
                        <td>@p.PaymentMethod</td>
                        <td><span class="badge bg-secondary">@p.Status</span></td>
                        <td class="text-end">@p.AmountPaid.ToString("N0")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Invoice" asp-route-id="@p.InvoiceId">Chi tiết</a>
                        </td>
                    </tr>
                    i++;
                }
            }
            </tbody>
        </table>
    </div>
</div>

