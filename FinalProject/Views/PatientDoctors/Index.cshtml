@model List<FinalProject.Models.Doctor>
@{
    ViewData["Title"] = "Danh sách bác sĩ";
    var specialties = (ViewData["Specialties"] as List<FinalProject.Models.Specialty>) ?? new();
    var selectedSpecialtyId = ViewData["SelectedSpecialtyId"] as int?;
    var q = (ViewData["Q"] as string) ?? "";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h2 class="mb-1">Danh sách bác sĩ</h2>
        <div class="text-muted">Tìm theo khoa/chuyên khoa và tên bác sĩ</div>
    </div>
    <a class="btn btn-outline-secondary" asp-controller="Dashboard" asp-action="Patient">Về dashboard</a>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form class="row g-2">
            <div class="col-md-4">
                <select class="form-select" name="specialtyId">
                    <option value="">-- Tất cả khoa/chuyên khoa --</option>
                    @foreach (var s in specialties)
                    {
                        <option value="@s.SpecialtyId" selected="@(selectedSpecialtyId == s.SpecialtyId)">
                            @s.SpecialtyName
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-5">
                <input class="form-control" name="q" value="@q" placeholder="Nhập tên bác sĩ / khoa / username..." />
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button class="btn btn-primary" type="submit">Lọc</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Reset</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-striped align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Bác sĩ</th>
                    <th>Khoa/Chuyên khoa</th>
                    <th>Phòng ban</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="5" class="text-center text-muted py-4">Không có bác sĩ phù hợp.</td>
                </tr>
            }
            else
            {
                var i = 1;
                foreach (var d in Model)
                {
                    <tr>
                        <td>@i</td>
                        <td>
                            <div class="fw-semibold">@d.User.FullName</div>
                            <div class="text-muted small">@d.User.Username</div>
                        </td>
                        <td>@d.Specialty?.SpecialtyName</td>
                        <td>@d.Department</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@d.DoctorId">Xem</a>
                        </td>
                    </tr>
                    i++;
                }
            }
            </tbody>
        </table>
    </div>
</div>

