@model IEnumerable<FinalProject.Models.Appointment>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-calendar-week"></i> My Appointment Schedule</h2>
    </div>

    <!-- ✅ SUCCESS / ERROR -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success text-center">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger text-center">
            @TempData["Error"]
        </div>
    }

    <!-- FILTER -->
    <form id="filterForm" asp-action="Index" method="get"
          class="row g-3 mb-4 bg-light p-3 rounded shadow-sm">

        <div class="col-md-6">
            <label class="form-label">Select Date (optional):</label>
            <input type="date" id="selectedDate" name="selectedDate"
                   value="@ViewBag.SelectedDate" class="form-control" />
        </div>

        <div class="col-md-3 d-flex align-items-end">
            <button type="button" id="clearDate" class="btn btn-secondary w-100">
                View by Week
            </button>
        </div>

        <div class="col-md-3 d-flex align-items-end">
            <span class="badge bg-info w-100 text-center p-2">
                Mode: @ViewBag.ViewMode
            </span>
        </div>

    </form>

    <!-- WEEK RANGE -->
    @if (ViewBag.ViewMode == "Week")
    {
        <div class="alert alert-info text-center">
            Week: @ViewBag.WeekRange
        </div>
    }

    <!-- NO DATA -->
    @if (ViewBag.Message != null)
    {
        <div class="alert alert-warning text-center">
            @ViewBag.Message
        </div>
    }

    <!-- TABLE -->
    @if (Model != null && Model.Any())
    {
        <table class="table table-hover table-bordered shadow-sm bg-white">
            <thead class="table-dark">
                <tr>
                    <th>Time</th>
                    <th>Patient Name</th>
                    <th>Reason</th>
                    <th>Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold text-primary">
                            @item.AppointmentDate.ToString("dd/MM/yyyy HH:mm")
                        </td>
                        <td>@item.Patient?.FullName</td>
                        <td>@item.Reason</td>
                        <td>
                            <span class="badge bg-success">@item.Status</span>
                        </td>
                        <td class="text-center">
                            <a asp-action="Reschedule"
                               asp-route-id="@item.AppointmentId"
                               class="btn btn-sm btn-warning">
                                Reschedule
                            </a>

                            <a asp-action="Cancel"
                               asp-route-id="@item.AppointmentId"
                               class="btn btn-sm btn-danger">
                                Cancel
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<!-- AUTO SWITCH SCRIPT -->
<script>
    const dateInput = document.getElementById("selectedDate");
    const form = document.getElementById("filterForm");
    const clearBtn = document.getElementById("clearDate");

    // 👉 chọn ngày → auto Day
    dateInput.addEventListener("change", function () {
        form.submit();
    });

    // 👉 bấm Week → clear date → auto Week
    clearBtn.addEventListener("click", function () {
        dateInput.value = "";
        form.submit();
    });

    // ✅ Auto hide alert sau 3s
    setTimeout(() => {
        const alerts = document.querySelectorAll('.alert');
        alerts.forEach(a => a.style.display = 'none');
    }, 5000);
</script>