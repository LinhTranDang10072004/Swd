@model FinalProject.Models.Appointment

<div class="container mt-4">
    <div class="card shadow-sm border-warning">
        <div class="card-header bg-warning text-dark">
            <h4><i class="bi bi-clock-history"></i> Reschedule Appointment</h4>
        </div>
        <div class="card-body">
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }

            <div class="mb-3 bg-light p-3 rounded">
                <p><strong>Patient:</strong> @Model.Patient?.FullName</p>
                <p><strong>Current Time:</strong> @Model.AppointmentDate.ToString("dd/MM/yyyy HH:mm")</p>
                <p><strong>Reason:</strong> @Model.Reason</p>
            </div>

            <form asp-action="Reschedule" method="post">
                <input type="hidden" name="appointmentId" value="@Model.AppointmentId" />

                <div class="mb-4">
                    <label class="form-label fw-bold">Select New Time:</label>
                    <input type="datetime-local" name="newTime" class="form-control"
                           min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" required />
                </div>
                <button type="submit" class="btn btn-primary">Confirm Reschedule</button>
                <a asp-action="Index" class="btn btn-secondary">Back to Schedule</a>
            </form>
        </div>
    </div>
</div>